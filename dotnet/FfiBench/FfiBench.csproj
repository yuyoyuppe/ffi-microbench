<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Pinned to the app's TFM (Directory.Build.props: BaseTargetFramework=net8.0-windows).
         net8.0 also activates the bindings' NET8_0_OR_GREATER fast paths
         (LibraryImport source-generated P/Invoke, BigEndianStream span paths). -->
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>preview</LangVersion>
    <!-- CS0162: the span-flavor bindings intentionally leave the original implementation
         unreachable after transparent delegation. CS8981/CS8500: mirrors csbindgen output. -->
    <NoWarn>$(NoWarn);CS0162;CS8981;CS8500;CS1591</NoWarn>
    <TieredPgo>true</TieredPgo>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.15.2" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\rust\target\release\benchffi.dll"
          CopyToOutputDirectory="PreserveNewest"
          Link="benchffi.dll" />
  </ItemGroup>

</Project>
